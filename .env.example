# База данных
DATABASE_URL=sqlite+aiosqlite:///./spacenews.db
DATABASE_URL_SYNC=sqlite:///./spacenews.db

# Для PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/spacenews
# DATABASE_URL_SYNC=postgresql://user:pass@localhost:5432/spacenews

# OpenAI / OpenRouter API (опционально, для ИИ-классификации)
# Для OpenAI:  OPENAI_API_KEY=sk-...
# Для OpenRouter: OPENAI_API_KEY=sk-or-v1-...
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Интервал парсинга (часы)
PARSER_INTERVAL_HOURS=2
